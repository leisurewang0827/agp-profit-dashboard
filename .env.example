# Copy this file to .env.local on each computer and fill values locally.
# Never commit real tokens, passwords, refresh tokens, or service role keys.

# Supabase
# SUPABASE_SERVICE_ROLE_KEY should be the legacy service_role JWT key
# from Project Settings > API Keys > Legacy anon, service_role API keys.
# The newer sb_secret_* key may not work with PostgREST /rest/v1 reads.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Meta Ads read-only reporting
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_BUSINESS_ID=

# Google Ads / GA4
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GA4_PROPERTY_ID=

# Naver
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_CUSTOMER_ID=
NAVER_COMMERCE_APPLICATION_ID=
NAVER_COMMERCE_APPLICATION_SECRET=

# Imweb
IMWEB_API_KEY=
IMWEB_API_SECRET=

# Notification targets
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=

# Obsidian export
OBSIDIAN_VAULT_PATH=


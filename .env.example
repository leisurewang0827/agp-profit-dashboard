# Copy this file to .env.local on each computer and fill values locally.
# Never commit real tokens, passwords, refresh tokens, or service role keys.

# Supabase
# SUPABASE_SERVICE_ROLE_KEY should be the legacy service_role JWT key
# from Project Settings > API Keys > Legacy anon, service_role API keys.
# The newer sb_secret_* key may not work with PostgREST /rest/v1 reads.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Instagram notices/promotions
# The current operation is not connected to Meta Ads Manager.
# Keep these empty unless Instagram is later connected to Meta Business/Ads.
INSTAGRAM_ACCOUNT_HANDLE=
INSTAGRAM_REPORT_SOURCE=manual

# Google Ads / GA4
# Keep these empty unless Google Ads or GA4 are actively used.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GA4_PROPERTY_ID=

# Naver Place / Naver SearchAd
# Naver Place is currently active. SearchAd keys are only needed if paid Naver ads
# are managed through Naver SearchAd and API reporting is enabled.
NAVER_PLACE_BUSINESS_NAME=
NAVER_PLACE_URL=
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_CUSTOMER_ID=

# Danggeun Ads
# Public API integration is not assumed. Start with manual/admin export tracking.
DAANGN_BUSINESS_PROFILE_URL=
DAANGN_REPORT_SOURCE=manual

# Inactive legacy channels
# Leave empty unless the operation changes later.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_BUSINESS_ID=
IMWEB_API_KEY=
IMWEB_API_SECRET=

# Notification targets
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=

# Obsidian export
OBSIDIAN_VAULT_PATH=


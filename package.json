{
  "name": "agp-profit-dashboard",
  "private": true,
  "version": "0.1.0",
  "description": "Static AGP profit dashboard artifacts and automation setup checks.",
  "scripts": {
    "check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-local-setup.ps1",
    "check:data": "node scripts/check-dashboard-data.mjs",
    "check:supabase": "node scripts/check-supabase.mjs",
    "check:automation": "node scripts/check-automation-runs.mjs",
    "check:briefing": "node scripts/check-daily-briefing.mjs",
    "briefing:daily": "node scripts/generate-daily-briefing.mjs",
    "verify:supabase-data": "node scripts/verify-supabase-data.mjs",
    "sync:supabase": "node scripts/sync-static-data-to-supabase.mjs",
    "sync:supabase:dry-run": "node scripts/sync-static-data-to-supabase.mjs --dry-run",
    "build:from-supabase": "node scripts/rebuild-dashboard-from-supabase.mjs",
    "refresh:daily": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-daily-refresh.ps1",
    "check:all": "npm.cmd run check && npm.cmd run check:data",
    "serve": "python -m http.server 4173"
  }
}

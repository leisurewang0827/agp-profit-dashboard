{
  "name": "agp-profit-dashboard",
  "private": true,
  "version": "0.1.0",
  "description": "Static AGP profit dashboard artifacts and automation setup checks.",
  "scripts": {
    "check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-local-setup.ps1",
    "check:data": "node scripts/check-dashboard-data.mjs",
    "check:supabase": "node scripts/check-supabase.mjs",
    "check:automation": "node scripts/check-automation-runs.mjs",
    "check:scheduler": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-scheduler.ps1",
    "check:api-readiness": "node scripts/check-api-readiness.mjs",
    "check:briefing": "node scripts/check-daily-briefing.mjs",
    "check:manual-channels": "node scripts/check-manual-channel-data.mjs",
    "check:deposit-dashboard": "node scripts/check-deposit-dashboard.mjs",
    "open:manual-console": "powershell -NoProfile -Command Start-Process (Resolve-Path 'manual-channel-console/index.html')",
    "manual:channels:dry-run": "node scripts/import-manual-channel-report.mjs",
    "manual:channels:import": "node scripts/import-manual-channel-report.mjs --write",
    "approval:create": "node scripts/create-approval-request.mjs",
    "approval:update": "node scripts/update-approval-request.mjs",
    "briefing:daily": "node scripts/generate-daily-briefing.mjs",
    "obsidian:briefing": "node scripts/export-daily-briefing-to-obsidian.mjs",
    "build:automation-status": "node scripts/build-automation-status-page.mjs",
    "verify:supabase-data": "node scripts/verify-supabase-data.mjs",
    "sync:supabase": "node scripts/sync-static-data-to-supabase.mjs",
    "sync:supabase:dry-run": "node scripts/sync-static-data-to-supabase.mjs --dry-run",
    "build:from-supabase": "node scripts/rebuild-dashboard-from-supabase.mjs",
    "refresh:daily": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-daily-refresh.ps1",
    "check:all": "npm.cmd run check && npm.cmd run check:data && npm.cmd run check:deposit-dashboard",
    "serve": "python -m http.server 4173"
  }
}
